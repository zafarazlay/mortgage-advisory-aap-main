# Environment Variables Example
# Copy this file to .env and fill in your actual values

# Supabase Configuration
VITE_SUPABASE_PROJECT_ID="your_project_id_here"
VITE_SUPABASE_PUBLISHABLE_KEY="your_publishable_key_here"
VITE_SUPABASE_URL="https://your_project.supabase.co"

# Stripe Configuration
# Get Publishable Key from https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLISHABLE_KEY="pk_test_YOUR_STRIPE_PUBLISHABLE_KEY"

# Stripe Secret Key (for backend/Supabase functions)
# Get Secret Key from https://dashboard.stripe.com/apikeys
# IMPORTANT: Never commit this key to Git, use .env.local instead
STRIPE_SECRET_KEY="sk_test_YOUR_STRIPE_SECRET_KEY"

# App URL (used for Stripe redirects)
VITE_APP_URL="http://localhost:5173"

# Google Sheets Configuration (optional)
# Instructions: https://docs.google.com/forms - create a form and get the form ID
# The webhook URL format: https://docs.google.com/forms/u/0/d/{FORM_ID}/formResponse
GOOGLE_SHEETS_WEBHOOK="https://docs.google.com/forms/u/0/d/YOUR_FORM_ID/formResponse"

# Slack Configuration (optional)
# Instructions: 
# 1. Go to https://api.slack.com/apps
# 2. Create a new app
# 3. Enable Incoming Webhooks
# 4. Create a new webhook and copy the URL
SLACK_WEBHOOK="https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK_URL"

# Airtable Configuration (optional)
# Instructions:
# 1. Get API token from https://airtable.com/account/tokens
# 2. Find your Base ID and Table ID in your Airtable workspace
AIRTABLE_TOKEN="YOUR_AIRTABLE_API_TOKEN"
AIRTABLE_BASE_ID="YOUR_BASE_ID"
AIRTABLE_TABLE_ID="YOUR_TABLE_ID"
